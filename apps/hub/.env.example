# ─────────────────────────────────────────────────────────────────────────
# Krmx Hub — apps/hub environment
# Copy to apps/hub/.env.local for local dev, or set these in Netlify for prod.
# NEVER commit real secrets. Every value below marked (secret) is sensitive.
# ─────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────
# Local docker Postgres (pnpm db:up). No TLS.
DATABASE_URL=postgres://hub:hub@localhost:5432/hub
# Production: Neon POOLED connection string (secret). TLS is auto-enabled for
# non-localhost hosts / sslmode=require. Use the *pooled* endpoint (…-pooler…).
#   DATABASE_URL=postgres://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/hub?sslmode=require

# ── Auth.js core ──────────────────────────────────────────────────────────
# Session cookie encryption/signing (secret). A dev fallback is compiled in for
# NODE_ENV=development; production refuses to start without this.
#   openssl rand -base64 32
AUTH_SECRET=
# Public URL of the hub; also used as the ticket `iss` claim. In prod set to the
# Netlify site URL (Auth.js also reads AUTH_URL). Defaults to localhost:3000.
AUTH_URL=http://localhost:3000
HUB_URL=http://localhost:3000

# ── Google OAuth (enabled only when both are set) ─────────────────────────
# Google Cloud console → OAuth client (Web). Authorized redirect URI:
#   <AUTH_URL>/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ── Resend magic links (enabled only when the key is set) ─────────────────
AUTH_RESEND_KEY=
# Verified sender for magic-link emails (Resend). onboarding@resend.dev works
# for testing; use your own verified domain in prod.
AUTH_EMAIL_FROM=onboarding@resend.dev

# ── Player ticket signing key (RS256) ─────────────────────────────────────
# PKCS8 PEM private key (secret); \n-escapes allowed on one line. A dev fallback
# ephemeral keypair is generated when unset; production requires it.
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048
# The public key is served at /.well-known/jwks.json with a `kid` = RFC 7638
# JWK thumbprint. Rotation (manual for now, see ARCHITECTURE §11): generate a
# new key, deploy it as TICKET_PRIVATE_KEY; the kid changes automatically, so
# verifiers pick up the new key via JWKS. Tickets live 2 minutes, so a brief
# overlap window is enough; serving both old+new keys during overlap is the
# deferred automation.
TICKET_PRIVATE_KEY=

# ── Hub config ────────────────────────────────────────────────────────────
# Bootstrap admin (ARCHITECTURE §2); defaults to mail@simonkarman.nl.
ADMIN_EMAIL=mail@simonkarman.nl
# CSP frame-src allowlist: registered game-frontend origins (comma separated).
HUB_FRAME_ORIGINS=http://localhost:4000
# Synchronous provision-call timeout in ms (default 60000).
# PROVISION_TIMEOUT_MS=60000
# Set to 1 to disable the in-process reaper (e.g. when a cron drives it).
# HUB_DISABLE_REAPER=1
