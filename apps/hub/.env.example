# Local Postgres from docker-compose (pnpm db:up)
DATABASE_URL=postgres://hub:hub@localhost:5432/hub

# Auth.js cookie secret. A dev fallback is compiled in for NODE_ENV=development;
# production (M6) refuses to start without this. Generate: openssl rand -base64 32
AUTH_SECRET=

# Bootstrap admin (ARCHITECTURE §2); defaults to mail@simonkarman.nl when unset.
ADMIN_EMAIL=mail@simonkarman.nl
